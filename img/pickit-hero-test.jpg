  <div class="_b-video-container_xqf8c_185 _hidden-md-sm-down_1hyau_92" id="video-box">
    <video muted playinline class="_b-video_xqf8c_185" id="video">
      <source src="assets/home/PICKIT_VIDEO_PRINCIPAL.webm" type="video/webm">
    </video>
  </div>

  <script type="text/javascript">
    const video = document.getElementById("video");

    let observerV = new IntersectionObserver(function (entries, self) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          video.play();
        }
      });
    }, );

    const container = document.getElementById("video-box");

    observerV.observe(container);
    
  </script>
</section>

